# ─── 数据库 ────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/tentacle_pro_db

# ─── 加密微信 APP_SECRET 密钥 ────────────────────────────────────────────────
# 32 字节随机密钥的 base64 编码
# 生成方式: bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64'))"
ENCRYPTION_KEY=<replace-with-base64-32-bytes>

# ─── API 服务 ─────────────────────────────────────────────────
WEB_PORT=3001
# 开发环境用development，生产环境用production
NODE_ENV=development
CORS_ORIGIN=*

# ─── 管理员账号设置 ────────────────────────────────────────────────
# 管理员密码（用于登录管理后台）
ADMIN_PASSWORD=<replace-with-your-admin-password>
# JWT 密钥（用于生成管理员登录的 JWT token）
ADMIN_JWT_SECRET=<replace-with-your-jwt-secret>