# Systemd 服务配置示例
# 适用于 Linux 生产环境（Ubuntu/Debian/RHEL）
#
# 两个服务文件：
#   1. tentacle-web.service  — Web 后台管理（端口 3000）
#   2. tentacle-api.service  — 外部 API 服务（端口 3001）
#
# 安装方式：
#   sudo cp docs/tentacle-web.service /lib/systemd/system/tentacle-web.service
#   sudo cp docs/tentacle-api.service /lib/systemd/system/tentacle-api.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable tentacle-web tentacle-api
#   sudo systemctl start  tentacle-web tentacle-api
#
# 查看日志：
#   journalctl -u tentacle-web -f
#   journalctl -u tentacle-api -f

# ─────────────────────────────────────────────
# 保存为 /lib/systemd/system/tentacle-web.service
# ─────────────────────────────────────────────
[Unit]
Description=Tentacle Pro — Web Dashboard (port 3000)
After=network.target postgresql.service

[Service]
Type=simple
User=tentacle
Group=tentacle
WorkingDirectory=/opt/tentacle-pro

# 生产环境变量，建议改为读取 EnvironmentFile
Environment=NODE_ENV=production
Environment=WEB_PORT=3000
# 以下敏感变量建议写入 /etc/tentacle/web.env 并用 EnvironmentFile 加载
# EnvironmentFile=/etc/tentacle/web.env
Environment=DATABASE_URL=postgres://tentacle:YOUR_PASSWORD@127.0.0.1:5432/tentacle_pro_db
Environment=ADMIN_PASSWORD=your-admin-password
Environment=ADMIN_JWT_SECRET=your-jwt-secret-at-least-32-chars

ExecStart=/root/.bun/bin/bun run web/src/index.ts

Restart=always
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=tentacle-web

[Install]
WantedBy=multi-user.target


# ─────────────────────────────────────────────
# 保存为 /lib/systemd/system/tentacle-api.service
# ─────────────────────────────────────────────
[Unit]
Description=Tentacle Pro — External API Service (port 3001)
After=network.target postgresql.service

[Service]
Type=simple
User=tentacle
Group=tentacle
WorkingDirectory=/opt/tentacle-pro

Environment=NODE_ENV=production
Environment=PORT=3001
# EnvironmentFile=/etc/tentacle/api.env
Environment=DATABASE_URL=postgres://tentacle:YOUR_PASSWORD@127.0.0.1:5432/tentacle_pro_db

ExecStart=/root/.bun/bin/bun run api/src/index.ts

Restart=always
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=tentacle-api

[Install]
WantedBy=multi-user.target
